<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="PortalAPI">
      <HintPath>..\Impro\dll\netstandard2.0\PortalAPI.dll</HintPath>
    </Reference>
    <!-- crypt.dll is required as per the documentation -->
    <Reference Include="crypt">
      <HintPath>..\Impro\dll\netstandard2.0\crypt.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <!-- Copy crypt.dll to output directory so it can be loaded at runtime -->
    <None Update="..\Impro\dll\netstandard2.0\crypt.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
